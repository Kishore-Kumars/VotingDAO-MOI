{
  "syntax": "PISA",
  "engine": { "kind": "MORU" },
  "elements": [
    {
      "ptr": 1,
      "kind": "state",
      "data": {
        "fields": [
          { "label": "dao_name", "type": "string" },
          { "label": "proposal_count", "type": "u64" },
          { "label": "quorum", "type": "u64" },
          { "label": "proposals", "type": "map[u64]Proposal" }
        ]
      }
    },
    {
      "ptr": 2,
      "kind": "state",
      "data": {
        "fields": [
          { "label": "token_balance", "type": "u64" },
          { "label": "participation_score", "type": "u64" },
          { "label": "proposals_created", "type": "u64" },
          { "label": "votes_cast", "type": "u64" },
          { "label": "is_member", "type": "bool" },
          { "label": "voted_proposals", "type": "map[u64]bool" }
        ]
      }
    },
    {
      "ptr": 3,
      "kind": "routine",
      "data": {
        "name": "Init",
        "kind": "deploy",
        "accepts": [
          { "label": "name", "type": "string" },
          { "label": "quorum_min", "type": "u64" }
        ],
        "returns": [],
        "executes": { "kind": "MORU", "bin": [] }
      }
    },
    {
      "ptr": 4,
      "kind": "routine",
      "data": {
        "name": "Register",
        "kind": "enlist",
        "accepts": [
          { "label": "initial_tokens", "type": "u64" }
        ],
        "returns": [],
        "executes": { "kind": "MORU", "bin": [] }
      }
    },
    {
      "ptr": 5,
      "kind": "routine",
      "data": {
        "name": "Propose",
        "kind": "invokable",
        "accepts": [
          { "label": "title", "type": "string" },
          { "label": "desc", "type": "string" }
        ],
        "returns": [],
        "executes": { "kind": "MORU", "bin": [] }
      }
    },
    {
      "ptr": 6,
      "kind": "routine",
      "data": {
        "name": "Vote",
        "kind": "invokable",
        "accepts": [
          { "label": "proposal_id", "type": "u64" },
          { "label": "choice", "type": "bool" }
        ],
        "returns": [],
        "executes": { "kind": "MORU", "bin": [] }
      }
    },
    {
      "ptr": 7,
      "kind": "routine",
      "data": {
        "name": "GetVoteWeight",
        "kind": "invokable",
        "accepts": [],
        "returns": [{ "type": "u64" }],
        "executes": { "kind": "MORU", "bin": [] }
      }
    },
    {
      "ptr": 8,
      "kind": "routine",
      "data": {
        "name": "GetProposal",
        "kind": "invokable",
        "accepts": [{ "label": "id", "type": "u64" }],
        "returns": [{ "type": "Proposal" }],
        "executes": { "kind": "MORU", "bin": [] }
      }
    },
    {
        "ptr": 9,
        "kind": "struct",
        "data": {
            "name": "Proposal",
            "fields": [
                { "label": "title", "type": "string" },
                { "label": "description", "type": "string" },
                { "label": "for_votes", "type": "u64" },
                { "label": "against_votes", "type": "u64" },
                { "label": "creator", "type": "address" }
            ]
        }
    }
  ]
}
